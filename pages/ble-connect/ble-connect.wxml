<view class="container">
  
  <view class="custom-nav">
    <view class="back-btn" bindtap="goBack"></view>
    <text class="nav-title">添加设备</text>
  </view>

  <view class="radar-section">
    <view class="radar-animation">
      <view class="circle-1 {{isSearching ? 'pulsing' : ''}}"></view>
      <view class="circle-2 {{isSearching ? 'pulsing-delay' : ''}}"></view>
      <view class="watch-center-icon"></view>
    </view>
    <text class="status-title">{{isSearching ? '正在搜索附近的腕表...' : '搜索完成'}}</text>
    <text class="status-sub">请确保设备已开机并靠近手机</text>
  </view>

  <view class="list-section">
    <text class="section-title">可用设备</text>
    
    <view class="device-list">
      <block wx:for="{{deviceList}}" wx:key="id">
        <view class="device-card" bindtap="connectDevice" data-name="{{item.name}}">
          
          <view class="device-info">
            <view class="device-icon"></view> <view class="text-group">
              <text class="device-name">{{item.name}}</text>
              <text class="device-mac">MAC: {{item.mac}}</text>
            </view>
          </view>

          <view class="action-group">
            <view class="signal-bars">
              <view class="bar {{item.signal > -80 ? 'active' : ''}}"></view>
              <view class="bar {{item.signal > -60 ? 'active' : ''}}"></view>
              <view class="bar {{item.signal > -50 ? 'active' : ''}}"></view>
            </view>
            <view class="connect-btn">连接</view>
          </view>
          
        </view>
      </block>
    </view>
  </view>

</view>