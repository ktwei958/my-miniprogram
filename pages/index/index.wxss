/* ========================================== */
/* 全局基础布局 */
/* ========================================== */
.container {
  min-height: 100vh;
  background-color: #000000;
  /* 底部 padding 增加到 200rpx，防止列表被底部导航栏挡住 */
  padding: 60rpx 40rpx 200rpx 40rpx;
  box-sizing: border-box;
  color: #FFFFFF;
}

/* ========================================== */
/* 头部区域：未连接状态 */
/* ========================================== */
.header-section {
  display: flex;
  align-items: center;
  margin-bottom: 80rpx;
}
.title-large {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 70rpx; 
}
.arrow-right {
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid rgba(255, 255, 255, 0.6);
  border-right: 4rpx solid rgba(255, 255, 255, 0.6);
  transform: rotate(45deg);
  margin-left: 20rpx;
}

/* ========================================== */
/* 头部区域：已连接状态 UI */
/* ========================================== */
.header-section-connected {
  display: flex;
  flex-direction: column;
  margin-bottom: 80rpx;
}
.device-title-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.connected-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 70rpx;
  line-height: 80rpx; /* 让 "AST的" 和 "RMB PRO" 换行后行距舒服 */
  white-space: pre-line; /* 识别文本里的 \n 换行符 */
}
/* Figma里的向下小三角 */
.polygon-arrow {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 16rpx solid rgba(255, 255, 255, 0.6);
  margin-left: 30rpx;
  margin-top: 30rpx;
}

/* 3个胶囊状态牌 */
.status-tags {
  display: flex;
  gap: 20rpx;
}
.status-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
}

/* 状态牌小圆点 */
.icon-dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.dot-blue { background: #209BFF; }
.dot-green { background: #36E153; }
.dot-orange { background: #FF9811; }

.pill-text {
  font-family: 'PingFang HK', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  opacity: 0.8;
}
.text-blue { color: #209BFF; }
.text-green { color: #36E153; }
.text-orange { color: #FF9811; }


/* ========================================== */
/* 列表区块基础样式 */
/* ========================================== */
.list-section {
  margin-bottom: 60rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 30rpx;
}
.section-title {
  font-family: 'Hiragino Sans GB', sans-serif;
  font-weight: 600;
  font-size: 44rpx; 
}
.view-more {
  font-size: 32rpx;
  color: rgba(54, 225, 83, 0.6); 
  font-weight: 500;
}

/* 空状态卡片 */
.empty-card {
  height: 150rpx;
  background: rgba(255, 255, 255, 0.11);
  border-radius: 56rpx; 
  display: flex;
  justify-content: center;
  align-items: center;
}
.empty-text {
  font-family: 'PingFang SC', sans-serif;
  font-size: 36rpx;
  color: #FFFFFF;
  opacity: 0.6;
}

/* 赛事卡片列表容器 */
.race-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* ========================================== */
/* 赛事卡片 (自由排版模式核心区域) */
/* ========================================== */
.race-card {
  position: relative; /* 核心：建立卡片内部坐标系 */
  width: 100%;        
  height: 206rpx;     
  background: rgba(255, 255, 255, 0.11);
  border-radius: 56rpx;
  overflow: hidden;   
}

/* 1. 卡片头部总容器 (名称 + ITRA标签 + 箭头) */
.card-header {
  position: absolute;
  left: 40rpx;
  top: 30rpx;
  right: 40rpx; /* 占据左右两侧空间 */
  display: flex;
  justify-content: space-between; /* 名字组靠左，小箭头靠右 */
  align-items: center;
}

/* 名字与标签打包组 */
.name-group {
  display: flex;
  align-items: center;
  gap: 16rpx; /* ITRA 标签与名字的间距 */
}

/* 赛事名称 (删除了原本的绝对定位) */
.race-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 32rpx;
  color: #FF9811;
}

/* ITRA 角标 (删除了原本的绝对定位，现在由 Flex 控制) */
.itra-tag {
  font-size: 20rpx;
  font-family: 'PingFang SC', sans-serif;
  font-weight: 500;
  color: #FF9811;
  margin-top: 4rpx; /* 微调：让它和名字的视觉中心稍微对齐一点 */
}

/* 右上角的小箭头 (删除了绝对定位) */
.arrow-right-small {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.5);
  border-right: 3rpx solid rgba(255, 255, 255, 0.5);
  transform: rotate(45deg);
}

/* 4. 比赛日期 (维持原有的绝对定位) */
.race-date {
  position: absolute;
  left: 40rpx;        
  top: 72rpx;         
  font-family: 'PingFang SC', sans-serif;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

/* 5. 赛事地点 (维持原有的绝对定位) */
.race-location {
  position: absolute;
  right: 40rpx;       
  top: 130rpx;         
  font-family: 'PingFang SC', sans-serif;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
  text-align: right;  
}

/* 6. 底部公里数 Tag 列表容器 (维持原有的绝对定位) */
.tag-container {
  position: absolute;
  left: 40rpx;        
  bottom: 26rpx;      
  display: flex;
  gap: 16rpx;
}

.distance-tag {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 3rpx 20rpx;
}

.distance-text {
  font-family: 'PingFang SC', sans-serif;
  font-size: 20rpx;
  font-weight: 300;
}

/* ========================================== */
/* 新增：底部自定义导航栏 */
/* ========================================== */
.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 166rpx; 
  background: #000000;
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding-top: 20rpx;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  /* 取消了强制的 opacity: 0.5，因为图标本身就是带透明度的 PNG */
  transition: all 0.2s ease;
}

/* 文字依旧需要根据是否 active 来改变透明度 */
.tab-item:not(.active) .tab-text {
  opacity: 0.5; 
}

.tab-item.active .tab-text {
  opacity: 1; 
}

/* ✨ 修改后的图标样式 */
.tab-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 8rpx;
  /* 已经删除了 background: #D9D9D9 和 border-radius，让你的透明背景 PNG 图标完美显示 */
}

.tab-text {
  font-family: 'Inter', sans-serif;
  font-size: 18rpx; 
  font-weight: 500;
  color: #FFFFFF;
}