/* 全局基础布局 */
.container {
  min-height: 100vh;
  background-color: #000000;
  padding: 0 40rpx 200rpx 40rpx; /* 留出底部导航栏的空间 */
  box-sizing: border-box;
  color: #FFFFFF;
}

.custom-nav {
  height: 180rpx;
  display: flex;
  align-items: flex-end;
  padding-bottom: 20rpx;
}
.nav-title {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 36rpx;
  margin-left: 20rpx;
}

/* ========================================== */
/* 顶部名片栏 */
/* ========================================== */
.user-card {
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.11);
  border-radius: 44rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}
.user-card:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.avatar-box {
  margin-right: 30rpx;
}
.default-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.user-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 36rpx;
  color: #FF9811; /* 品牌橙色 */
}
.user-desc {
  font-family: 'PingFang SC', sans-serif;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.arrow-right {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid rgba(255, 255, 255, 0.5);
  border-right: 4rpx solid rgba(255, 255, 255, 0.5);
  transform: rotate(45deg);
}

/* ========================================== */
/* 功能菜单列表 */
/* ========================================== */
.menu-list {
  margin-top: 60rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 44rpx;
  padding: 10rpx 40rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 0;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.05);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-text {
  font-family: 'PingFang SC', sans-serif;
  font-size: 30rpx;
  font-weight: 500;
}
.arrow-right-small {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.3);
  border-right: 3rpx solid rgba(255, 255, 255, 0.3);
  transform: rotate(45deg);
}

/* ========================================== */
/* 底部自定义导航栏 */
/* ========================================== */
.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 166rpx; 
  background: #000000;
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding-top: 20rpx;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.tab-item:not(.active) .tab-text {
  opacity: 0.5; 
}

.tab-item.active .tab-text {
  opacity: 1; 
}

.tab-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-family: 'Inter', sans-serif;
  font-size: 18rpx; 
  font-weight: 500;
  color: #FFFFFF;
}